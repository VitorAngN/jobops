{
  "name": "jobops",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "api:dev": "npm run dev -w apps/api",
    "api:build": "npm run build -w apps/api",
    "api:typecheck": "npm run typecheck -w apps/api",
    "api:test": "npm run test -w apps/api",
    "api:prisma:generate": "npm run prisma:generate -w apps/api",
    "api:prisma:migrate": "npm run prisma:migrate -w apps/api",
    "api:prisma:seed": "npm run prisma:seed -w apps/api",
    "web:dev": "npm run dev -w apps/web",
    "web:build": "npm run build -w apps/web",
    "web:typecheck": "npm run typecheck -w apps/web",
    "extra:desktop:start": "electron apps/desktop/main.cjs",
    "extra:desktop:shortcut": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-desktop-shortcut.ps1",
    "desktop:start": "npm run extra:desktop:start",
    "desktop:shortcut": "npm run extra:desktop:shortcut",
    "typecheck": "npm run api:typecheck && npm run web:typecheck",
    "build": "npm run api:build && npm run web:build",
    "test": "npm run api:test"
  },
  "devDependencies": {
    "electron": "^42.2.0"
  }
}
